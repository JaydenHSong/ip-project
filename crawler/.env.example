# Sentinel Web API
SENTINEL_API_URL=http://localhost:3000
SENTINEL_SERVICE_TOKEN=your_service_token_here

# Redis (BullMQ) — Railway Redis or Upstash
# Railway: REDIS_URL is auto-injected. Or set UPSTASH_REDIS_URL manually.
REDIS_URL=redis://default:xxx@redis.railway.internal:6379

# Bright Data Browser API (Scraping Browser)
BRIGHTDATA_BROWSER_WS=wss://brd-customer-xxx-zone-scraping_browser1:password@brd.superproxy.io:9222

# Crawler Settings
CRAWLER_CONCURRENCY=3
CRAWLER_PAGE_DELAY_MIN=2000
CRAWLER_PAGE_DELAY_MAX=5000
CRAWLER_DETAIL_DELAY_MIN=1500
CRAWLER_DETAIL_DELAY_MAX=4000
CRAWLER_MAX_RETRIES=3

# Google Chat Webhook (optional)
GOOGLE_CHAT_WEBHOOK_URL=
